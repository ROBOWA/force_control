    <general class="panda" name="actuator5" joint="joint5" gainprm="1" biastype="none" ctrlrange="-87 87"/>
    <general class="panda" name="actuator6" joint="joint6" gainprm="1" biastype="none" ctrlrange="-87 87"/>
    <general class="panda" name="actuator7" joint="joint7" gainprm="1" biastype="none" ctrlrange="-87 87"/>

    <!-- Gripper: unchanged, position-controlled PD on tendon "split"
         ctrl range 0-255, Kp=50, Kd=2 -->
    <general class="panda" name="actuator8" tendon="split" forcerange="-300 300" ctrlrange="0 255" gainprm="50 0 0" biasprm="0 -50 -2"/>
  </actuator>

  <keyframe>
    <!-- ctrl for arm joints set to 0 [Nm] (torque control: controller takes over immediately)
         qpos unchanged from original home configuration -->
    <key name="home" qpos="0 0 0 -1.57079 0 1.57079 -0.7853 0.04 0.04" ctrl="0 0 0 0 0 0 0 0"/>
  </keyframe>

  <sensor>
    <force  name="ft_force"  site="ft_sensor_site"/>
    <torque name="ft_torque" site="ft_sensor_site"/>
    <!-- 左右手指夹持力传感器（局部坐标系三维力，仅用于监测，不参与控制） -->
    <force name="left_finger_force"  site="left_finger_contact"/>
    <force name="right_finger_force" site="right_finger_contact"/>
  </sensor>

  <contact>
    <exclude body1="link0" body2="link1"/>
    <pair geom1="left_finger_col" geom2="right_finger_col" solref="0.001 1" solimp="0.999 0.9999 0.0001 0.5 2"/>
    <pair geom1="left_finger_col" geom2="stick_collision"/>
    <pair geom1="right_finger_col" geom2="stick_collision"/>
  </contact>
</mujoco>
